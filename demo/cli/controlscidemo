def run_track1(case_file: Path, quick: bool, sample_count: int | None):
    print(f"\n{sep('═')}")
    print(f"  {header('Track1')} — {bold('ControlMind Sci-Align')} (科学数据对齐与跨模态评测)")
    print(f"  {dim(f'数据源: {case_file}')}")
    print(f"{sep('═')}")

    if not case_file.exists():
        print(f"  {error(f'{glyph('✗', '[FAIL]')} 样例文件不存在: {case_file}')}")
        return False

    cases = split_cases(case_file)
    if not cases:
        print(f"  {error(f'{glyph('✗', '[FAIL]')} 未能解析出任何 case，请检查文件格式')}")
        return False

    selected, mode_message = choose_cases(cases, quick, sample_count)
    print(f"  {mode_message}")

    start = time.time()
    for i, case in enumerate(selected, 1):
        print_case_track1(case, i, len(cases))

    elapsed = time.time() - start
    print(f"\n  {success(f'{glyph('✓', '[OK]')} Track1 完成')} — {len(selected)} 题, 耗时 {elapsed:.1f}s")
    print(f"  {dim('验收标准: controlscidemo track1 --quick 在 30s 内完成')}")
    if elapsed > 30:
        print(f"  {warn(f'{glyph('△', '[WARN]')} 耗时 {elapsed:.1f}s 超过 30s 基准线')}")
    return True


