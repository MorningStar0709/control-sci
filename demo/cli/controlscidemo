def main():
    parser = argparse.ArgumentParser(
        description="ControlMind Demo CLI — 三赛道快速验证入口",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
示例:
  python demo/cli/controlscidemo track1 --quick
  python demo/cli/controlscidemo track2 --quick
  python demo/cli/controlscidemo track3 --sample 10
  python demo/cli/controlscidemo all --quick
        """,
    )
    parser.add_argument(
        "track",
        choices=["track1", "track2", "track3", "all"],
        help="赛道选择: track1 (Sci-Align), track2 (Agent), track3 (Medical RAG), all (全部)",
    )
    parser.add_argument(
        "--quick",
        action="store_true",
        help=f"快速模式: 每赛道只展示前 {QUICK_COUNT} 题",
    )
    parser.add_argument(
        "--sample",
        type=int,
        metavar="N",
        help="展示前 N 题 (覆盖 --quick)",
    )

    args = parser.parse_args()

    if args.sample is not None and args.sample < 1:
        print(f"\n{error(f'{glyph('✗', '[FAIL]')} --sample 必须为正整数，收到: {args.sample}')}")
        sys.exit(1)

    sample_count = args.sample if args.sample else None
    quick = args.quick and sample_count is None

    now_str = time.strftime("%Y-%m-%d %H:%M:%S")
    print(f"\n{bold('ControlMind Demo CLI')}")
    print(f"{dim(f'项目根目录: {PROJECT_ROOT}')}")
    print(f"{dim(f'时间: {now_str}')}")

    tracks = {
        "track1": (TRACK1_CASES, run_track1),
        "track2": (TRACK2_CASES, run_track2),
        "track3": (TRACK3_CASES, run_track3),
    }

    overall_start = time.time()

    if args.track == "all":
        ok = True
        for name, (case_file, runner) in tracks.items():
            try:
                ok = runner(case_file, quick, sample_count) and ok
            except Exception as e:
                ok = False
                print(f"\n  {error(f'{glyph('✗', '[FAIL]')} {name} 执行异常')}")
                print(f"  {error(str(e))}")
        if not ok:
            print(f"\n{error(f'{glyph('✗', '[FAIL]')} 至少一个赛道执行失败')}")
            sys.exit(1)
    else:
        case_file, runner = tracks[args.track]
        try:
            if not runner(case_file, quick, sample_count):
                sys.exit(1)
        except Exception as e:
            print(f"\n  {error(f'{glyph('✗', '[FAIL]')} {args.track} 执行异常')}")
            print(f"  {error(str(e))}")
            sys.exit(1)

    overall_elapsed = time.time() - overall_start
    print(f"\n{sep('═')}")
    print(f"  {success(f'{glyph('✓', '[OK]')} CLI 执行完毕')} — 总耗时 {overall_elapsed:.1f}s")
    print(f"{sep('═')}\n")


if __name__ == "__main__":
    try:
        main()
    except KeyboardInterrupt:
        print(f"\n{warn('中断退出')}")
        sys.exit(130)
    except FileNotFoundError as e:
        print(f"\n{error(f'文件未找到: {e}')}")
        print(f"{dim('请确认在项目根目录 (d:/WorkPlace/AI/MinerU) 下运行')}")
        sys.exit(1)
    except Exception as e:
        print(f"\n{error(f'未预期的错误: {type(e).__name__}: {e}')}")
        sys.exit(1)
