{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "meta": {
    "project": "ControlSci Data Agent",
    "schema_version": "1.0",
    "intent_version": "1.0.0",
    "updated": "2026-05-08",
    "total_intents": 14,
    "description": "科学文档跨模态语料智能体 — 14 intent 能力注册表",
    "source": "docs/plans/track2-final-push-plan.md §五",
    "architecture": {
      "layer_1": "Intent Router (LLM few-shot — DeepSeek v4-flash)",
      "layer_2": "Resource Scheduler (四路径: API / MiMo-V2.5 视觉 / Ollama 本地 / MinerU)",
      "layer_3": "Executor + Verifier (Execute → Verify → Auto-fallback)",
      "data_boundary": "云端处理公开/脱敏派生任务；原文解析按数据分级路由，公开资料可显式使用官方 API，私有/涉密资料默认本地"
    },
    "privacy_policy": {
      "principle": "cloud_for_public_or_sanitized_local_for_private",
      "cloud_allowed": [
        "公开论文检索",
        "公开分级文档解析（需显式 allow_cloud_upload）",
        "脱敏统计分析",
        "评测题生成与仲裁",
        "排行榜与报告生成"
      ],
      "local_only": [
        "医疗文献 RAG",
        "私有/涉密/企业原文解析",
        "QLoRA 微调数据",
        "原始 PDF/图像/中间 chunk"
      ]
    }
  },
  "intents": [
    {
      "intent_id": "arxiv_search",
      "rank": 0,
      "name": "arXiv 论文检索",
      "description": "使用自研 searching-arxiv-papers Skill 在 arXiv 上检索 2025-2026 年控制科学前沿论文并下载 PDF。这是 Agent 数据飞轮的起点——「从论文检索到排行榜更新」全自动闭环的第 0 步。",
      "trigger_examples": [
        "检索 2025 年控制科学新论文加入评测基准",
        "搜索 control barrier function 方向的 arXiv 论文",
        "自动发现并下载 5 篇控制科学前沿论文"
      ],
      "toolchain": [
        "searching-arxiv-papers Skill",
        "arXiv API"
      ],
      "resource_type": "script",
      "data_source": "arXiv API (export.arxiv.org)",
      "depends_on": [],
      "auto_fallback": [],
      "provider_requirements": {
        "provider": "arXiv API",
        "endpoint_required": false,
        "capabilities": [
          "paper_search",
          "pdf_download",
          "deduplication"
        ]
      },
      "parameters": {
        "type": "object",
        "additionalProperties": false,
        "required": [],
        "properties": {
          "keywords": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "检索关键词列表",
            "default": [
              "control barrier function",
              "differentiable MPC"
            ]
          },
          "max_papers": {
            "type": "integer",
            "description": "下载论文数上限",
            "default": 5,
            "minimum": 1,
            "maximum": 10
          },
          "output_dir": {
            "type": "string",
            "description": "PDF 输出目录",
            "default": "data/sources_flywheel/"
          }
        }
      },
      "output": {
        "type": "arxiv_papers",
        "format": "pdf",
        "description": "下载的 arXiv 论文 PDF 文件",
        "artifacts": [
          "{arxiv_id}_{title}.pdf",
          "flywheel_papers.json"
        ]
      }
    },
